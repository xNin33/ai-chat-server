# Copy this file to .env and fill in what you need, or set these as real
# environment variables in your hosting platform (Docker, systemd, Render,
# Railway, Fly.io, etc). All values shown are the defaults if unset.

# Port the server listens on
PORT=3000

# Upstream OpenAI-compatible chat completions endpoint that /api/chat proxies to.
# Examples:
#   https://api.openai.com/v1/chat/completions
#   https://api.deepseek.com/v1/chat/completions
#   https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
#   http://localhost:11434/v1/chat/completions   (Ollama, local)
CHAT_UPSTREAM=https://api.openai.com/v1/chat/completions

# Optional: server-side fallback API key. If set, used whenever the browser
# doesn't send its own Authorization header (i.e. the user left "API Key"
# blank in Settings). Leave empty to require every user to supply their own
# key in the app.
SERVER_API_KEY=

# Upstream search endpoint that /api/search proxies to.
#   Serper.dev:    https://google.serper.dev/search   (POST, needs SEARCH_API_KEY)
#   SearXNG:       https://your-searx-instance/search  (GET ?q=&format=json)
#   DuckDuckGo:    https://api.duckduckgo.com/          (GET ?q=&format=json, default)
SEARCH_UPSTREAM=https://api.duckduckgo.com/

# API key for the search provider, if it requires one (e.g. Serper's X-API-KEY).
SEARCH_API_KEY=

# Path to the frontend HTML file to serve. Defaults to AI.html next to server.js.
FRONTEND_FILE=

# Max JSON body size accepted (image attachments can be large base64 blobs).
BODY_LIMIT=50mb

# Simple per-IP rate limit on /api/* routes. Set RATE_LIMIT_MAX=0 to disable.
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# CORS origin allowed to call this server's /api/* routes. Only relevant if
# you host the frontend separately from this server. "*" allows any origin.
CORS_ORIGIN=*

# Set to "true" to enable POST /api/chat-to?upstream=<url>, which lets the
# client pick the upstream per-request via a query param. Off by default —
# this is an SSRF risk if exposed publicly without additional auth.
ALLOW_CUSTOM_UPSTREAM=false
